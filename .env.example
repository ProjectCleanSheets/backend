# Copy to .env for local development (vercel dev). Real values live in the Vercel
# dashboard and /Users/kris/Documents/Projects/CleanSheets/Credentials/CREDENTIALS.md
# — never commit them.

SUPABASE_URL=
# Server-side only. RLS is enabled, the anon key cannot access tables.
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — defaults to the production callback URL. Set locally to
# http://localhost:3000/auth/google/callback (must be registered on the OAuth client).
GOOGLE_REDIRECT_URI=
ENABLE_BANKING_APP_ID=
# Full PEM contents as a single value
ENABLE_BANKING_PRIVATE_KEY=
# "sandbox" or "production"
ENABLE_BANKING_ENV=sandbox
# Optional — defaults to the production callback URL. Set locally to
# http://localhost:3000/auth/bank/callback (must be registered in the Enable Banking control panel).
ENABLE_BANKING_REDIRECT_URI=
# Optional, DEV ONLY — consent validity in days for new bank connections.
# Float, must be in (0, 180]; anything else falls back to the 90-day default.
# Set to e.g. 0.01 (≈ 15 min) to test the BANK_TOKEN_EXPIRED expiry path for
# real. Production (Vercel) must NOT set this.
ENABLE_BANKING_CONSENT_DAYS=
# 32 bytes, hex (64 chars) or base64 — AES-256-GCM key for encrypting tokens
ENCRYPTION_KEY=
