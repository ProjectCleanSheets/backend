# Copy to .env for local development (vercel dev). Real values live in the Vercel
# dashboard and /Users/kris/Documents/Projects/CleanSheets/Credentials/CREDENTIALS.md
# — never commit them.

SUPABASE_URL=
# Server-side only. RLS is enabled, the anon key cannot access tables.
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ENABLE_BANKING_APP_ID=
# Full PEM contents as a single value
ENABLE_BANKING_PRIVATE_KEY=
# "sandbox" or "production"
ENABLE_BANKING_ENV=sandbox
# 32 bytes, hex (64 chars) or base64 — AES-256-GCM key for encrypting tokens
ENCRYPTION_KEY=
