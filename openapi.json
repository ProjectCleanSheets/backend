{
  "openapi": "3.0.3",
  "info": {
    "title": "CleanSheets Backend",
    "version": "1.0.0",
    "description": "Bridge between the CleanSheets iOS app, Google Sheets, Enable Banking, and Supabase. All endpoints require `Authorization: Bearer <google_id_token>` unless noted. Sign in with Google at the top of this page to auto-authorize Try-it-out requests."
  },
  "servers": [
    { "url": "/", "description": "This deployment" }
  ],
  "components": {
    "securitySchemes": {
      "googleIdToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Google ID token issued for the CleanSheets client ID"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "SHEET_WRITE_FAILED",
              "SHEET_NOT_FOUND",
              "BANK_TOKEN_EXPIRED",
              "GOOGLE_TOKEN_EXPIRED",
              "SUPABASE_ERROR",
              "CATEGORY_NOT_FOUND",
              "INVALID_REQUEST"
            ]
          },
          "message": { "type": "string" }
        }
      },
      "ColumnMapping": {
        "type": "object",
        "description": "Per-section column layout, e.g. { \"Expenses\": { \"category_col\": \"F\", \"actual_col\": \"H\" } }",
        "additionalProperties": {
          "type": "object",
          "required": ["category_col", "actual_col"],
          "properties": {
            "category_col": { "type": "string", "pattern": "^[A-Z]{1,2}$", "example": "F" },
            "actual_col": { "type": "string", "pattern": "^[A-Z]{1,2}$", "example": "H" },
            "budget_col": { "type": "string", "pattern": "^[A-Z]{1,2}$", "example": "G" },
            "left_col": { "type": "string", "pattern": "^[A-Z]{1,2}$", "example": "I" }
          }
        }
      },
      "UserConfig": {
        "type": "object",
        "properties": {
          "sheetId": { "type": "string", "nullable": true },
          "columnMapping": {
            "allOf": [{ "$ref": "#/components/schemas/ColumnMapping" }],
            "nullable": true
          }
        }
      },
      "SheetTabs": {
        "type": "object",
        "required": ["tabs"],
        "properties": {
          "tabs": {
            "type": "array",
            "items": { "type": "string" },
            "example": ["July", "August", "_log"]
          }
        }
      },
      "SheetStructure": {
        "type": "object",
        "required": ["tab", "sections"],
        "properties": {
          "tab": { "type": "string", "example": "July" },
          "sections": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "columns", "categories"],
              "properties": {
                "name": { "type": "string", "example": "Expenses" },
                "columns": {
                  "type": "object",
                  "required": ["category", "budget", "actual"],
                  "properties": {
                    "category": { "type": "string", "example": "F" },
                    "budget": { "type": "string", "example": "G" },
                    "actual": { "type": "string", "example": "H" },
                    "left": { "type": "string", "nullable": true, "example": "I" }
                  }
                },
                "categories": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["name"],
                    "properties": {
                      "name": { "type": "string", "example": "Groceries" },
                      "budget": { "type": "number", "nullable": true, "example": 3100 },
                      "actual": { "type": "number", "nullable": true, "example": 3580 }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid Google ID token",
        "content": {
          "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
        }
      }
    }
  },
  "security": [{ "googleIdToken": [] }],
  "paths": {
    "/api/auth/google": {
      "post": {
        "tags": ["auth"],
        "summary": "Sign in — verify ID token and create the user row if missing",
        "responses": {
          "200": {
            "description": "Signed in",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "googleId": { "type": "string" },
                    "hasConfig": { "type": "boolean", "description": "true when a sheet_id is saved" },
                    "hasSheetsAccess": { "type": "boolean", "description": "true when a Sheets-scope refresh token is stored" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "tags": ["auth"],
        "summary": "Start the Google Sheets consent flow (action=start)",
        "description": "Returns the Google consent URL that grants the backend a Sheets-scope refresh token. Open the returned URL in a browser. The callback (`/auth/google/callback`) is browser-only and not testable here.",
        "parameters": [
          {
            "name": "action",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "enum": ["start"] }
          }
        ],
        "responses": {
          "200": {
            "description": "Consent URL",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "url": { "type": "string" } } }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "405": {
            "description": "Unsupported method or action",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/auth/bank": {
      "get": {
        "tags": ["auth"],
        "summary": "Start the Enable Banking consent flow",
        "description": "Returns the bank authorization URL (MitID in production, instant approval at Mock ASPSP in sandbox). Open the returned URL in a browser. In sandbox `bank`/`country` default to the Mock ASPSP; in production both are required. The callback (`/auth/bank/callback`) is browser-only and not testable here.",
        "parameters": [
          {
            "name": "bank",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "minLength": 1, "maxLength": 100 },
            "description": "ASPSP name as listed by Enable Banking, e.g. \"Nordea\""
          },
          {
            "name": "country",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "pattern": "^[A-Z]{2}$", "example": "DK" },
            "description": "Two-letter ISO country code of the bank"
          }
        ],
        "responses": {
          "200": {
            "description": "Bank authorization URL",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "url": { "type": "string" } } }
              }
            }
          },
          "400": {
            "description": "Missing/invalid bank selection or bank rejected the request",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "405": {
            "description": "Unsupported method or action",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "500": {
            "description": "Server configuration, credential, or storage failure — message names the failing step",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "502": {
            "description": "Enable Banking unavailable",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/sheet/structure": {
      "get": {
        "tags": ["sheet"],
        "summary": "List tabs, or scan one tab's sections/categories/columns",
        "description": "Without `tab`: returns the spreadsheet's tab names. With `tab`: scans the tab and returns detected sections, their categories (with Budget/Actual values), and column positions. Opens the sheet with the caller's stored Sheets consent — a sheet the account cannot access returns `SHEET_NOT_FOUND`; missing/expired consent returns `GOOGLE_TOKEN_EXPIRED`.",
        "parameters": [
          {
            "name": "sheetId",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "pattern": "^[a-zA-Z0-9_-]{20,100}$" },
            "description": "Google Sheet ID (from the sheet URL)"
          },
          {
            "name": "tab",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "minLength": 1, "maxLength": 100 },
            "description": "Tab name to scan, e.g. \"July\". Omit to list tabs."
          }
        ],
        "responses": {
          "200": {
            "description": "Tab list (no `tab` param) or detected structure (`tab` given)",
            "content": {
              "application/json": {
                "schema": {
                  "oneOf": [
                    { "$ref": "#/components/schemas/SheetTabs" },
                    { "$ref": "#/components/schemas/SheetStructure" }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid sheetId or tab parameter",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Sheet or tab not found, or not accessible to this Google account",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          }
        }
      }
    },
    "/api/user/config": {
      "get": {
        "tags": ["user"],
        "summary": "Get the caller's saved config",
        "responses": {
          "200": {
            "description": "Current config (fields are null until saved)",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/UserConfig" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "post": {
        "tags": ["user"],
        "summary": "Save sheet ID and/or column mapping",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sheetId": { "type": "string", "pattern": "^[a-zA-Z0-9_-]{20,100}$" },
                  "columnMapping": { "$ref": "#/components/schemas/ColumnMapping" }
                }
              },
              "example": {
                "columnMapping": { "Expenses": { "category_col": "F", "budget_col": "G", "actual_col": "H", "left_col": "I" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Saved config",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/UserConfig" } }
            }
          },
          "400": {
            "description": "Validation failed",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/Error" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  }
}
